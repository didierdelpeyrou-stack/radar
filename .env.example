# RADAR — variables d'environnement. Copier en .env (jamais commité).
# Le code est identique entre Supabase Cloud (pilote MVP, région UE) et le
# self-host H/IA : seules ces variables changent (§5).

# URL de l'instance Supabase (self-hosted H/IA en prod, Cloud UE pour le pilote)
VITE_SUPABASE_URL=https://radar.h-ia.fr
# Clé publique "anon" (RLS active : aucune donnée accessible sans session)
VITE_SUPABASE_ANON_KEY=

# Feature flag V2 : pré-estimation OpenFisca (instance auto-hébergée H/IA)
VITE_FEATURE_OPENFISCA=false
VITE_OPENFISCA_URL=
